        "@media (max-width: 767px) {.availability-slider .instamart-logo {min-width: 120px; height: 40px; } .availability-slider .instamart-logo span {font-size: 21px; }}"
      ],
      "settings": {
        "custom_liquid": "<section class=\"availability-section\">\n  <h2>NOW ALSO AVAILABLE</h2>\n  <p>Shop our premium products online with ease. Fast delivery & exclusive deals await!</p>\n\n  <div class=\"scroll-hint\">\n    ← Swipe / Scroll →\n  </div>\n\n  <div class=\"availability-slider\">\n\n    <a href=\"https://www.amazon.in/Marino-Collection-occasions-valentine-Boyfriend/dp/B0DTLGQC24\" target=\"_blank\" rel=\"noopener\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/amazon-ombrebliss.svg?v=1782286302\" alt=\"Amazon\" loading=\"lazy\">\n    </a>\n\n    <a href=\"https://www.flipkart.com/search?q=Ombre+bliss&marketplace=FLIPKART&as-show=on&pageUID=1740047749140\" target=\"_blank\" rel=\"noopener\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/Flipkart-ombrebliss.svg?v=1782286302\" alt=\"Flipkart\" loading=\"lazy\">\n    </a>\n\n    <a href=\"https://www.myntra.com/ombre-bliss?rawQuery=ombre%20bliss\" target=\"_blank\" rel=\"noopener\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/myntra-ombrebliss.svg?v=1782286302\" alt=\"Myntra\" loading=\"lazy\">\n    </a>\n\n    <a href=\"https://www.ajio.com/search/?text=ombre%20bliss\" target=\"_blank\" rel=\"noopener\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/ajio-logo-brandlogos.net_vzrwvgzda.svg?v=1782286302\" alt=\"AJIO\" loading=\"lazy\">\n    </a>\n\n    <a href=\"https://blinkit.com/prn/ombre-bliss-marino-eau-de-parfum-ozonic/prid/652393?srsltid=AfmBOoopwOqI1wJl4KuB7uW3x4N4HwAy9j5lh15UdBqlxw0OR53BpzZy\" target=\"_blank\" rel=\"noopener\" class=\"marketplace-logo\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/blinkit-logo-app-icon-transparent-background-free-png_1.webp?v=1782286303\" alt=\"Blinkit\" loading=\"lazy\">\n    </a>\n\n    <a href=\"https://www.firstcry.com/search?q=ombre%20bliss%20perfume&ref2=q_ombre%20bliss%20perfume\" target=\"_blank\" rel=\"noopener\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/firstcry.webp?v=1782286302\" alt=\"FirstCry\" loading=\"lazy\">\n    </a>\n\n    <a href=\"https://www.swiggy.com/stores/instamart/collection-listing?collectionId=106463&custom_back=true&brand=Ombre%20Bliss\" target=\"_blank\" rel=\"noopener\" class=\"marketplace-logo\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/instamart_logo.jpg?v=1782286302\" alt=\"Instamart\" loading=\"lazy\">\n    </a>\n\n  </div>\n</section>\n\n<style>\n  .availability-section {\n    text-align: center;\n    margin: 60px auto;\n    overflow: hidden;\n    width: 100%;\n  }\n\n  .availability-section h2 {\n    font-size: 28px;\n    font-weight: 700;\n    margin: 0;\n  }\n\n  .availability-section p {\n    margin-top: 10px;\n    color: #666;\n    font-size: 15px;\n  }\n\n  .scroll-hint {\n    margin-top: 22px;\n    font-size: 14px;\n    color: #888;\n    font-weight: 500;\n    animation: swipeAnim 1.5s infinite;\n  }\n\n  @keyframes swipeAnim {\n    0% { transform: translateX(0px); }\n    50% { transform: translateX(8px); }\n    100% { transform: translateX(0px); }\n  }\n\n  .availability-slider {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 50px;\n    padding: 38px 30px 15px;\n    max-width: 1200px;\n    margin: 0 auto;\n    overflow-x: visible;\n    scrollbar-width: none;\n  }\n\n  .availability-slider::-webkit-scrollbar {\n    display: none;\n  }\n\n  .availability-slider a {\n    width: 130px;\n    height: 55px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .availability-slider img {\n    max-width: 130px;\n    max-height: 55px;\n    width: auto;\n    height: auto;\n    object-fit: contain;\n    display: block;\n    transition: transform 0.3s ease;\n  }\n\n  .availability-slider .marketplace-logo {\n    width: 150px;\n    height: 60px;\n  }\n\n  .availability-slider .marketplace-logo img {\n    max-width: 150px;\n    max-height: 60px;\n  }\n\n  .availability-slider a:hover img {\n    transform: scale(1.06);\n  }\n\n  @media (max-width: 1024px) {\n    .availability-slider {\n      justify-content: flex-start;\n      overflow-x: auto;\n      gap: 40px;\n      padding-left: 24px;\n      padding-right: 24px;\n    }\n  }\n\n  @media (max-width: 767px) {\n    .availability-section {\n      margin: 45px auto;\n    }\n\n    .availability-section h2 {\n      font-size: 22px;\n    }\n\n    .availability-section p {\n      font-size: 13px;\n      padding: 0 18px;\n    }\n\n    .scroll-hint {\n      font-size: 12px;\n      margin-top: 16px;\n    }\n\n    .availability-slider {\n      justify-content: flex-start;\n      overflow-x: auto;\n      gap: 28px;\n      padding: 28px 16px 12px;\n    }\n\n    .availability-slider a {\n      width: 105px;\n      height: 42px;\n    }\n\n    .availability-slider img {\n      max-width: 105px;\n      max-height: 42px;\n    }\n\n    .availability-slider .marketplace-logo {\n      width: 125px;\n      height: 50px;\n    }\n\n    .availability-slider .marketplace-logo img {\n      max-width: 125px;\n      max-height: 50px;\n    }\n  }\n</style>"
