{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#efe8df"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "NEWSLETTER SIGN UP"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter Subtext",
      "default": "Sign up for exclusive updates, new arrivals & insider only discounts"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        { "type": "link_list" },
        { "type": "link_list" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .custom-footer {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 60px 40px 40px;
    font-family: inherit;
  }
  .custom-footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }
  .custom-footer-top {
    display: flex;
    flex-wrap: wrap;
    gap: 80px;
  }
  .custom-footer-col {
    min-width: 200px;
  }
  .custom-footer-heading {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 25px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ section.settings.text_color }};
  }
  .custom-footer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .custom-footer-menu li {
    margin-bottom: 15px;
  }
  .custom-footer-menu a {
    text-decoration: none;
    color: {{ section.settings.text_color }};
    font-size: 15px;
    transition: opacity 0.3s;
    opacity: 0.8;
  }
  .custom-footer-menu a:hover {
    opacity: 1;
  }
  
  .custom-footer-bottom {
    display: flex;
    flex-direction: column;
    max-width: 600px;
  }
  .custom-footer-newsletter-sub {
    font-size: 14px;
    margin-bottom: 15px;
    opacity: 0.9;
  }
  .custom-footer-form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .custom-footer-input {
    flex: 1;
    min-width: 250px;
    padding: 12px 15px;
    border: 1px solid #999;
    background: #fff;
    font-size: 14px;
    outline: none;
    color: #000;
  }
  .custom-footer-input::placeholder {
    color: #666;
  }
  .custom-footer-btn {
    padding: 12px 30px;
    background: #fff;
    border: 1px solid #999;
    color: #000;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.3s;
  }
  .custom-footer-btn:hover {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  @media screen and (max-width: 768px) {
    .custom-footer {
      padding: 40px 20px;
    }
    .custom-footer-top {
      gap: 40px;
      flex-direction: column;
    }
    .custom-footer-col {
      min-width: 100%;
    }
  }
</style>

<footer class="custom-footer">
  <div class="custom-footer-container">
    
    <div class="custom-footer-top">
      {%- for block in section.blocks -%}
        <div class="custom-footer-col">
          <div class="custom-footer-heading">{{ block.settings.heading }}</div>
          {%- if block.settings.menu != blank -%}
            <ul class="custom-footer-menu">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- else -%}
            <ul class="custom-footer-menu">
              <li><a href="#">Shop All</a></li>
              <li><a href="#">Couture Collection</a></li>
              <li><a href="#">Classic Collection</a></li>
              <li><a href="#">Shop By</a></li>
              <li><a href="#">Shop By Gender</a></li>
              <li><a href="#">Gift Sets</a></li>
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="custom-footer-bottom">
      <div class="custom-footer-heading">{{ section.settings.newsletter_heading }}</div>
      <div class="custom-footer-newsletter-sub">{{ section.settings.newsletter_subtext }}</div>
      
      {% form 'customer', class: 'custom-footer-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" class="custom-footer-input" placeholder="enter your email address" required>
        <button type="submit" class="custom-footer-btn">SUBMIT</button>
      {% endform %}
    </div>

  </div>
</footer>
