{%- if product.metafields.custom.ingredients != blank -%}
  <style>
    .ingredients-section-{{ section.id }} { text-align: center; margin-top: 20px; position: relative; max-width: 100%; padding: 40px 0; }
    .ingredients-title-{{ section.id }} { font-size: 15px; font-weight: 600; margin-bottom: 12px; }
    .ingredients-scroll-wrapper-{{ section.id }} { position: relative; overflow: hidden; max-width: 1240px; margin: 0 auto; }
    .ingredients-scroll-container-{{ section.id }} { display: flex; overflow-x: auto; scroll-behavior: smooth; padding: 5px 10px; gap: 10px; -webkit-overflow-scrolling: touch; }
    .ingredients-scroll-container-{{ section.id }}::-webkit-scrollbar { height: 6px; }
    .ingredients-scroll-container-{{ section.id }}::-webkit-scrollbar-track { background: #f1f1f1; }
    .ingredients-scroll-container-{{ section.id }}::-webkit-scrollbar-thumb { background: #777; border-radius: 10px; }
    .ingredients-item-{{ section.id }} { flex: 0 0 auto; width: 110px; text-align: center; }
    .ingredients-item-{{ section.id }} img { width: 75px; height: 75px; border-radius: 10px; object-fit: cover; aspect-ratio: 1 / 1; display: block; margin: 0 auto; }
    .ingredients-item-{{ section.id }} p { margin-top: 6px; font-weight: 600; font-size: 13px; line-height: 1.2; color: #000; }
    .scroll-arrow-{{ section.id }} { position: absolute; top: 50%; transform: translateY(-50%); font-size: 24px; color: #444; background-color: rgba(255,255,255,0.85); border-radius: 50%; width: 30px; height: 30px; line-height: 30px; text-align: center; cursor: pointer; z-index: 1; user-select: none; box-shadow: 0 0 4px rgba(0,0,0,0.15); }
    .scroll-arrow-{{ section.id }}.left { left: 5px; }
    .scroll-arrow-{{ section.id }}.right { right: 5px; }
    @media (max-width: 600px) { .scroll-arrow-{{ section.id }} { display: none; } }
  </style>

  <section class="ingredients-section-{{ section.id }}" id="ingredients-{{ section.id }}">
    <div class="ingredients-title-{{ section.id }}">{{ section.settings.heading }}</div>
    <div class="ingredients-scroll-wrapper-{{ section.id }}">
      <div class="scroll-arrow-{{ section.id }} left" onclick="scrollIngredientsLeft_{{ section.id | replace: '-', '_' }}()">‹</div>
      <div class="scroll-arrow-{{ section.id }} right" onclick="scrollIngredientsRight_{{ section.id | replace: '-', '_' }}()">›</div>

      <div class="ingredients-scroll-container-{{ section.id }}" id="ingredients-scroll-container-{{ section.id }}">
        {%- for ingredient in product.metafields.custom.ingredients.value -%}
          <div class="ingredients-item-{{ section.id }}">
            {%- assign ing_name = ingredient.name.value | default: ingredient.name -%}
            {%- assign ing_img = ingredient.image.value | default: ingredient.image -%}
            
            {%- if ing_img != blank -%}
              {%- if ing_img.media_type or ing_img.src -%}
                <img loading="lazy" src="{{ ing_img | image_url: width: 150 }}" width="75" height="75" alt="{{ ing_name | escape }}">
              {%- else -%}
                <img loading="lazy" src="{{ ing_img }}" width="75" height="75" alt="{{ ing_name | escape }}">
              {%- endif -%}
            {%- else -%}
              <div style="width:75px;height:75px;border-radius:10px;background:#eee;margin:0 auto;display:flex;align-items:center;justify-content:center;">🌿</div>
            {%- endif -%}
            <p>{{ ing_name }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <script>
    function scrollIngredientsLeft_{{ section.id | replace: '-', '_' }}() {
      document.getElementById("ingredients-scroll-container-{{ section.id }}").scrollBy({ left: -180, behavior: "smooth" });
    }
    function scrollIngredientsRight_{{ section.id | replace: '-', '_' }}() {
      document.getElementById("ingredients-scroll-container-{{ section.id }}").scrollBy({ left: 180, behavior: "smooth" });
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Ingredients Slider",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ingredients Behind the Fragrance"
    }
  ],
  "presets": [
    {
      "name": "Ingredients Slider"
    }
  ]
}
{% endschema %}