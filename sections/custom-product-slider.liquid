<style>
  .custom-product-slider--{{ section.id }} {
    padding: {{ section.settings.padding_y }}px 0;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }
  .custom-product-slider__track-wrapper {
    display: flex;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  .custom-product-slider__track-wrapper::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }
  .custom-product-slider__track {
    display: flex;
    gap: 15px;
    padding: 10px 20px;
    align-items: center;
  }
  .custom-product-slider__item {
    flex-shrink: 0;
    width: 250px; /* Fixed width for marquee items */
    text-align: center;
    text-decoration: none;
  }
  .custom-product-slider__image-wrapper {
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    padding-bottom: 100%; /* square ratio */
    margin-bottom: 15px;
  }
  .custom-product-slider__image-wrapper img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .custom-product-slider__item:hover img {
    transform: scale(1.05);
  }
  .custom-product-slider__price-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .custom-product-slider__price {
    font-size: 14px;
    font-weight: 600;
    color: #000;
  }
  .custom-product-slider__compare-price {
    font-size: 12px;
    text-decoration: line-through;
    color: #888;
  }
  


  @media screen and (max-width: 750px) {
    .custom-product-slider__item {
      width: 180px;
    }
  }
  @media screen and (max-width: 480px) {
    .custom-product-slider__item {
      width: 150px;
    }
  }
</style>

<div class="custom-product-slider--{{ section.id }}" id="product-slider-{{ section.id }}">
  <div class="custom-product-slider__track-wrapper" data-speed="{{ section.settings.speed }}">
    {%- assign products = collections['all'].products -%}
    {%- for i in (1..3) -%}
      <div class="custom-product-slider__track" {% if i > 1 %}aria-hidden="true"{% endif %} style="padding-right: 15px;">
        {%- if products.size > 0 -%}
          {%- for product in products limit: section.settings.limit -%}
            <a href="{{ product.url }}" class="custom-product-slider__item">
              <div class="custom-product-slider__image-wrapper">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="custom-product-slider__price-wrapper">
                <span class="custom-product-slider__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="custom-product-slider__compare-price">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- for j in (1..6) -%}
            <div class="custom-product-slider__item">
              <div class="custom-product-slider__image-wrapper">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="custom-product-slider__price-wrapper">
                <span class="custom-product-slider__price">$19.99</span>
                <span class="custom-product-slider__compare-price">$29.99</span>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('product-slider-{{ section.id }}');
    if (!section) return;
    const wrapper = section.querySelector('.custom-product-slider__track-wrapper');
    if (!wrapper) return;
    
    // section.settings.speed is e.g. 30
    const speed = parseInt(wrapper.getAttribute('data-speed')) || 30; 
    const increment = speed / 30; 
    
    let isHovered = false;
    let isTouching = false;
    let animationId;
    let currentScroll = 0;

    function autoScroll() {
      if (!isHovered && !isTouching) {
        currentScroll += increment;
        const singleTrackWidth = wrapper.scrollWidth / 3;
        
        if (wrapper.scrollLeft >= singleTrackWidth) {
           wrapper.scrollLeft -= singleTrackWidth;
           currentScroll = wrapper.scrollLeft;
        } else {
           wrapper.scrollLeft = currentScroll;
        }
      } else {
        currentScroll = wrapper.scrollLeft;
      }
      animationId = requestAnimationFrame(autoScroll);
    }
    
    wrapper.addEventListener('mouseenter', () => isHovered = true);
    wrapper.addEventListener('mouseleave', () => isHovered = false);
    wrapper.addEventListener('touchstart', () => isTouching = true, {passive: true});
    wrapper.addEventListener('touchend', () => {
      isTouching = false;
      currentScroll = wrapper.scrollLeft;
    }, {passive: true});
    
    wrapper.addEventListener('scroll', () => {
      if (isHovered || isTouching) {
        currentScroll = wrapper.scrollLeft;
      }
    }, {passive: true});
    
    animationId = requestAnimationFrame(autoScroll);
  });
</script>

{% schema %}
{
  "name": "Custom Product Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 30,
      "step": 1,
      "label": "Maximum products to show",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top/Bottom Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Custom Product Slider"
    }
  ]
}
{% endschema %}
