<style>
  .custom-brand-slider--{{ section.id }} {
    padding: {{ section.settings.padding_y }}px 0;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    position: relative;
    width: 100%;
    margin-top: {{ section.settings.mg_top }}px;
    margin-bottom: {{ section.settings.mg_bottom }}px;
  }
  .custom-brand-slider__title {
    text-align: center;
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    margin-bottom: 20px;
    font-weight: 500;
  }
  .custom-brand-slider__track {
    display: flex;
    gap: {{ section.settings.gap }}px;
    align-items: center;
    /* CSS animation for endless scroll */
    animation: custom-marquee {{ section.settings.speed }}s linear infinite;
  }
  .custom-brand-slider__track:hover {
    animation-play-state: paused;
  }
  .custom-brand-slider__item {
    flex-shrink: 0;
    width: {{ section.settings.image_width }}px;
    text-align: center;
  }
  .custom-brand-slider__item img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    transition: transform 0.3s ease;
  }
  .custom-brand-slider__item:hover img {
    transform: scale(1.05);
  }
  .custom-brand-slider__item span {
    display: block;
    margin-top: 10px;
    font-size: 14px;
    color: {{ section.settings.text_color }};
  }
  @keyframes custom-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% - {{ section.settings.gap }}px)); }
  }
  /* Mobile adjustments */
  @media screen and (max-width: 768px) {
    .custom-brand-slider--{{ section.id }} {
      padding: {{ section.settings.padding_y | divided_by: 2 }}px 0;
      margin-top: {{ section.settings.mg_top | divided_by: 2 }}px;
      margin-bottom: {{ section.settings.mg_bottom | divided_by: 2 }}px;
    }
    .custom-brand-slider__item {
      width: {{ section.settings.image_width | divided_by: 1.5 }}px;
    }
  }
</style>

<div class="custom-brand-slider--{{ section.id }}">
  {%- if section.settings.title != blank -%}
    <div class="custom-brand-slider__title">{{ section.settings.title }}</div>
  {%- endif -%}

  <!-- We create a wrapper that is much wider than the screen to let items flow horizontally -->
  <div style="display: flex;">
    {%- for i in (1..3) -%}
      <div class="custom-brand-slider__track" {% if i > 1 %}aria-hidden="true"{% endif %} style="padding-right: {{ section.settings.gap }}px;">
        {%- for block in section.blocks -%}
          <div class="custom-brand-slider__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}">
            {%- endif -%}
            
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            
            {%- if block.settings.title != blank -%}
              <span>{{ block.settings.title }}</span>
            {%- endif -%}

            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Custom Brand Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Brands"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Heading Size",
      "default": 30
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Image Width",
      "default": 150
    },
    {
      "type": "range",
      "id": "gap",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between items",
      "default": 30
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top & Bottom Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "mg_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "mg_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Brand Name (Optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Brand Slider",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
