{%- comment -%} Ombre Bliss — v12 product page (brand kit). Real variants/prices + % codes. {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{%- assign ob_fonts = 'https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Raleway:wght@300;400;500;600;700&display=swap' -%}
<link rel="preload" as="style" href="{{ ob_fonts }}" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ ob_fonts }}"></noscript>
{{ 'ob-v12.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sc_ids = 'smoky,blu,leather,oud,tobacco,vanilla,amberrose,angel,pistachio,candy' | split: ','
  assign sc_handles = 'smoky-rum,ombre-blu-perfume,classical-leather-perfume,nawab-oud-perfume,royale-tobacco-perfume,vanilla-kiss-perfume,amber-rose-unisex-perfume,angel-perfume,pistachio-pop-perfume,lush-candy-perfume' | split: ','
  assign cur_scent = 'smoky'
  for id in sc_ids
    if sc_handles[forloop.index0] == product.handle
      assign cur_scent = id
    endif
  endfor
-%}

<div class="obv12">
<div class="wrap">
<section class="pdp">
  <div class="gal">
    <div class="thumbs" id="thumbs"></div>
    <div class="frame" id="frame">
      <div class="gscale" id="gscale">100ml — shown to scale</div>
      <img class="mainimg" id="mainImg" src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title | escape }}">
    </div>
  </div>

  <div class="buy">
    <div class="hd">
      <div><div class="lbl">The Couture Collection</div><h1 id="pName">{{ product.title | escape }}</h1></div>
      <div class="conc-tag">Extrait 25%</div>
    </div>
    <p class="line1" id="pLine"></p>
    <div class="rate"><span class="st">★★★★★</span><span style="font-weight:600">4.7</span><a href="#obv12-reviews">Reviews</a><span class="vb">✓ Verified buyers</span></div>

    <div class="prof" id="prof"></div>

    <div class="strip">
      <div class="st-tab" id="stTab"></div>
      <div class="st-body"><div class="st-dots" id="stDots"></div><div class="st-t"><div class="st-n" id="stN"></div><div class="st-d" id="stD"></div></div></div>
    </div>

    <div class="sec"><div class="sec-h"><div class="lbl">Choose your size</div></div><div class="sizes" id="sizes"></div></div>
    <div class="sec"><div class="sec-h"><div class="lbl">Choose your scent</div><div class="lbl" id="famL"></div></div><div class="chips" id="chips"></div></div>

    <div class="sec">
      <div class="sec-h"><div class="lbl">How many</div><div class="lbl">Mix any scents</div></div>
      <div id="tiers"></div>
      <div class="bulk" id="bulk">
        <button class="bulk-h" id="bulkH"><span class="bulk-plus" aria-hidden="true"><i></i><i></i></span><span class="bulk-txt"><span class="t">Buy more, pay less per bottle</span><span class="s" id="bulkSub"></span></span><span class="bulk-cta" id="bulkCta">Open</span></button>
        <div class="bulk-b"><div class="bulk-in"><div class="bulk-hook" id="bulkHook"></div><div class="lad" id="lad"></div><div class="nudge" id="nudge"></div></div></div>
      </div>
      <div class="pick" id="pick"></div>
      <div class="save" id="save" style="display:none"><span>You're saving</span><b id="saveAmt">₹0</b></div>
    </div>

    <div class="fbt">
      <div class="fbt-h"><span class="lbl">Frequently bought together</span><span class="fbt-sv" id="fbtSv"></span></div>
      <div class="fbt-list" id="fbtList"></div>
      <div class="fbt-foot"><div class="fbt-tot"><span class="l">Total for <b id="fbtN">3</b> items</span><span class="r"><s id="fbtWas"></s><b id="fbtAmt">₹0</b></span></div><button class="fbt-btn" id="fbtBtn">Add all to cart</button></div>
    </div>

    <div class="tot"><span class="l">Total</span><span class="r"><span class="was" id="wasAmt"></span><span class="amt" id="totAmt">₹0</span></span></div>
    <div class="ctas"><button class="cta" id="cta">Add to cart</button><button class="cta buy" id="ctaBuy">Buy now</button></div>
    <div class="cta-n" id="ctaN"></div>

    <div class="secure"><svg viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="10" rx="1"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>Secure checkout · 256-bit SSL encrypted</div>
    <div class="pays"><span class="pay">UPI</span><span class="pay">GPay</span><span class="pay">PhonePe</span><span class="pay">Paytm</span><span class="pay">Visa</span><span class="pay">Mastercard</span><span class="pay">RuPay</span></div>
    <div class="ship"><div class="ship-t"><div class="ship-f" id="shipF"></div></div><div class="ship-x" id="shipX"></div></div>

    <div class="trust">
      <div class="tr"><svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.5-3 8.2-7 10-4-1.8-7-5.5-7-10V6z"/><path d="M9 12l2 2 4-4"/></svg><b>100% authentic</b>Bottled in our own unit</div>
      <div class="tr"><svg viewBox="0 0 24 24"><path d="M12 3s6 7 6 11a6 6 0 0 1-12 0c0-4 6-11 6-11z"/></svg><b>25% oil</b>Extrait, not eau de toilette</div>
      <div class="tr"><svg viewBox="0 0 24 24"><path d="M4 12a8 8 0 0 1 13.7-5.7L20 8"/><path d="M20 4v4h-4"/><path d="M20 12a8 8 0 0 1-13.7 5.7L4 16"/><path d="M4 20v-4h4"/></svg><b>7-day exchange</b>Swap the scent, no fuss</div>
      <div class="tr"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"/><path d="M12 8v4l3 2"/></svg><b>Ships in 24 hrs</b>Tracked across India</div>
    </div>
  </div>
</section>
</div>

<section class="below" id="obv12-reviews">
  <div class="wrap duo">
    <div>
      <div class="lbl">Verified purchases</div>
      <h2 class="h2">What they said</h2>
      <div class="rv-top">
        <div class="rv-sc">4.7</div>
        <div class="rv-bars">
          <div class="rv-b"><span>5</span><span class="t"><i style="width:78%"></i></span><span>78%</span></div>
          <div class="rv-b"><span>4</span><span class="t"><i style="width:14%"></i></span><span>14%</span></div>
          <div class="rv-b"><span>3</span><span class="t"><i style="width:5%"></i></span><span>5%</span></div>
          <div class="rv-b"><span>2</span><span class="t"><i style="width:2%"></i></span><span>2%</span></div>
          <div class="rv-b"><span>1</span><span class="t"><i style="width:1%"></i></span><span>1%</span></div>
        </div>
      </div>
      <div class="rv-stats">
        <div class="rv-s"><div class="n">8.4 hrs</div><div class="l">Avg longevity</div></div>
        <div class="rv-s"><div class="n">91%</div><div class="l">Got a compliment</div></div>
        <div class="rv-s"><div class="n">62%</div><div class="l">Bought a second</div></div>
      </div>
      <div class="rev"><div class="s">★★★★★</div><div class="t">Can smell different notes as the day progresses. Worth every rupee.</div><div class="m"><span class="vb">✓ Verified</span> Pallavi G.</div></div>
      <div class="rev"><div class="s">★★★★★</div><div class="t">Deep, rich scent with excellent longevity. Sprayed at 9am, still there at night.</div><div class="m"><span class="vb">✓ Verified</span> Bharat B.</div></div>
      <div class="rev"><div class="s">★★★★★</div><div class="t">Works in any weather. Tried it in Delhi summer and winter both.</div><div class="m"><span class="vb">✓ Verified</span> Anjali S.</div></div>
    </div>
    <div>
      <div class="lbl">Before you buy</div>
      <h2 class="h2">Questions we get asked</h2>
      <div class="faq" id="faq" style="margin-top:16px"></div>
    </div>
  </div>
</section>
</div>

{%- render 'ob-related',
  heading: 'From the Classic Collection',
  handles: 'marino-perfume-for-him,vicious-perfume-for-him,yazuka-perfume-for-him,honour-perfume-for-him,the-bouquet-perfume-for-her,obsessed-perfume-for-her,luna-perfume-for-her,pierce-perfume-for-her' -%}

<div class="obv12-satc" id="satc">
  <div class="satc-in">
    <div class="satc-b"><span class="j" id="satcJ"></span></div>
    <div class="satc-i"><div class="satc-n" id="satcN">{{ product.title | escape }}</div><div class="satc-m" id="satcM"></div></div>
    <div class="satc-sv" id="satcSv"></div>
    <div class="satc-p"><span class="w" id="satcW"></span><span class="a" id="satcA">₹0</span></div>
    <div class="satc-btn"><button id="satcAdd">Add to cart</button><button class="buy" id="satcBuy">Buy now</button></div>
  </div>
</div>
<div class="obv12-toast" id="toast"></div>

<script>
window.OB_V12 = {
  currentScent: {{ cur_scent | json }},
  codePrefix: 'OBC',
  variants: {
  {%- assign couture = collections['premium-collection'] -%}
  {%- assign first_v = true -%}
  {%- for pr in couture.products -%}
    {%- assign sidx = -1 -%}
    {%- for h in sc_handles -%}{%- if h == pr.handle -%}{%- assign sidx = forloop.index0 -%}{%- break -%}{%- endif -%}{%- endfor -%}
    {%- if sidx > -1 -%}
      {%- assign sid = sc_ids[sidx] -%}
      {%- assign v100 = nil -%}{%- assign v25 = nil -%}
      {%- for v in pr.variants -%}{%- if v.title contains '100' -%}{%- assign v100 = v -%}{%- elsif v.title contains '25' -%}{%- assign v25 = v -%}{%- endif -%}{%- endfor -%}
      {%- assign img100 = v100.image | default: pr.featured_image -%}
      {%- assign img25 = v25.image | default: pr.featured_image -%}
      {%- unless first_v -%},{%- endunless -%}{%- assign first_v = false -%}
      {{ sid | json }}: { "v100": {{ v100.id | default: 'null' }}, "v25": {{ v25.id | default: 'null' }}, "img100": {{ img100 | image_url: width: 800 | json }}, "img25": {{ img25 | image_url: width: 800 | json }}, "imgs": [ {%- for im in pr.images limit: 6 -%}{{ im | image_url: width: 800 | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%} ], "url": {{ pr.url | json }} }
    {%- endif -%}
  {%- endfor -%}
  },
  noteImages: {
  {%- assign first_ni = true -%}
  {%- for pr in couture.products -%}
    {%- for ing in pr.metafields.custom.ingredients.value -%}
      {%- assign iname = ing.name.value | default: ing.name -%}
      {%- assign iimg = ing.image.value | default: ing.image -%}
      {%- if iname != blank and iimg != blank -%}
        {%- unless first_ni -%},{%- endunless -%}{%- assign first_ni = false -%}
        {{ iname | strip | json }}: {{ iimg | image_url: width: 400 | json }}
      {%- endif -%}
    {%- endfor -%}
  {%- endfor -%}
  }
};
</script>
<script src="{{ 'ob-v12.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "OB Product v12",
  "tag": "section",
  "class": "ob-product-v12",
  "settings": [
    { "type": "paragraph", "content": "Brand-kit product page. Reads Couture variants, prices and the ob discount codes. Assign via the 'v12' product template." }
  ],
  "presets": [ { "name": "OB Product v12" } ]
}
{% endschema %}
