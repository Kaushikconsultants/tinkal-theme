let tt;
function toast(m){$('toast').textContent=m; $('toast').classList.add('up'); clearTimeout(tt); tt=setTimeout(()=>$('toast').classList.remove('up'),3200);}
function lineItem(){
  const counts={};
  combo.forEach(id=>{counts[id]=(counts[id]||0)+1;});
  return Object.entries(counts).map(([id,n])=>(n>1?n+'× ':'')+S(id).name).join(', ');
}
/* Shopify: replace these with /cart/add.js and /cart/:variantId:qty?checkout */
function addToCart() {
  const btn = $('ctaBuy');
  const oldText = btn.innerText;
  btn.innerText = 'Adding...';
  
  // 1. Get the current selected product name and convert to handle
  const currentScent = window.currentScent || SCENTS.find(s => s.id === cur).name;
  const handle = currentScent.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
  const selectedSize = cfg().label; // e.g. "100ml" or "25ml"
  const quantity = qty;
  
  // 2. Fetch the product JSON from Shopify to get the variant ID
  fetch(`/products/${handle}.js`)
    .then(res => {
      if (!res.ok) throw new Error('Product not found on store');
      return res.json();
    })
    .then(productData => {
      // Find variant matching the size
      const variant = productData.variants.find(v => v.title.toLowerCase().includes(selectedSize.toLowerCase()) || v.option1.toLowerCase().includes(selectedSize.toLowerCase()));
      if (!variant) throw new Error(`Size ${selectedSize} not found for this product`);
      
      // 3. Add to cart
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variant.id, quantity: quantity })
      });
    })
    .then(res => res.json())
    .then(cartData => {
      btn.innerText = 'Added!';
      toast(`✓ Added to cart — ${currentScent} ${selectedSize}`);
      // Refresh cart drawer if exists
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: cartData } }));
      if (window.theme && window.theme.CartDrawer) window.theme.CartDrawer.open();
      setTimeout(() => btn.innerText = oldText, 2000);
    })
    .catch(err => {
      console.error(err);
      btn.innerText = 'Error';
      toast(`Could not add to cart: ${err.message}`);
      setTimeout(() => btn.innerText = oldText, 3000);
    });
}
function buyNow() {
  const btn = $('ctaBuy');
  const oldText = btn.innerText;
  btn.innerText = 'Redirecting...';
  
  const currentScent = window.currentScent || SCENTS.find(s => s.id === cur).name;
  const handle = currentScent.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
  const selectedSize = cfg().label;
  const quantity = qty;
  
  fetch(`/products/${handle}.js`)
    .then(res => res.json())
    .then(productData => {
      const variant = productData.variants.find(v => v.title.toLowerCase().includes(selectedSize.toLowerCase()) || v.option1.toLowerCase().includes(selectedSize.toLowerCase()));
      if (!variant) throw new Error(`Size ${selectedSize} not found`);
      
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variant.id, quantity: quantity })
      });
    })
    .then(() => {
      window.location.href = '/checkout';
    })
    .catch(err => {
      console.error(err);
      toast(`Error: ${err.message}`);
      btn.innerText = oldText;
    });
}
$('cta').onclick=addToCart; $('stickyCta').onclick=addToCart;
$('ctaBuy').onclick=buyNow;  $('stickyBuy').onclick=buyNow;
new IntersectionObserver(([e])=>{$('sticky').classList.toggle('up',!e.isIntersecting);},{threshold:0}).observe($('cta'));

/* boot */
fitCombo();
renderSizes(); renderTiers(); renderBulk(); renderPicker(); renderAddons(); paintScent(); calc(); drydown(); renderIngredients(); renderLab(); renderPresets(); renderCombos(); paintSeg();
</script>



