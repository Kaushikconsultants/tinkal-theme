/* â”€â”€ DRYDOWN â”€â”€ */
function drydown(){
  const v=+$('ddSlider').value;
  const st=STAGES[v<15?0:v<35?1:v<70?2:3];
  $('ddTime').textContent=st.t; $('ddStage').textContent=st.s; $('ddDesc').textContent=st.d(cur);
  const all=[...cur.top.map(n=>[n,'top']),...cur.mid.map(n=>[n,'mid']),...cur.base.map(n=>[n,'base'])];
  $('ddNotes').innerHTML=all.map(([n,k])=>`<span class="dd-note ${k===st.k?'lit':''}">${n}</span>`).join('');
  $('cLine').setAttribute('x1',v*5); $('cLine').setAttribute('x2',v*5);
  const L=cur.longevity;
  const mk=(peak,decay,h)=>{let d='';for(let x=0;x<=500;x+=10){const t=x/500,rise=1-Math.exp(-t/(peak+.01)),fall=Math.exp(-Math.max(0,t-peak)/decay);d+=(x===0?'M':'L')+x+' '+(220-(rise*fall)*h*(L/10)).toFixed(1)+' ';}return d;};
  $('cTop').setAttribute('d',mk(.05,.12,175));
  $('cMid').setAttribute('d',mk(.22,.32,165));
  $('cBase').setAttribute('d',mk(.45,1.4,150));
}
$('ddSlider').oninput=drydown;

/* â”€â”€ LAYERING â”€â”€ */
function shared(a,b){return S(a).base.filter(n=>S(b).base.includes(n)).length;}
function pairOf(a,b){return PAIRS.find(p=>p.a===a&&p.b===b);}
function scoreOf(a,b){
  if(a===b) return 0;
  const p=pairOf(a,b); if(p) return p.score;
  const A=S(a),B=S(b); let sc=52;
  sc+=Math.min(24,Math.abs(A.weight-B.weight)*3.2);
  sc+=shared(a,b)*9;
  sc+= A.weight>=B.weight ? 8 : -6;
  if(A.sweet>7&&B.sweet>7) sc-=8;
  return Math.max(38,Math.min(98,Math.round(sc)));
}
function bestPartner(a){
  let best=null;
  SCENTS.forEach(s=>{ if(s.id===a) return;
    const sc=scoreOf(a,s.id);
    if(!best||sc>best.score) best={id:s.id,score:sc,n:(pairOf(a,s.id)||{}).n};
  });
  return best;
}
function autoDesc(a,b){
  const A=S(a),B=S(b),sh=shared(a,b);
  return `${A.name} goes down first â€” ${A.base[0].toLowerCase()} and ${A.base[1].toLowerCase()} do the anchoring. ${B.name} lands on top with ${B.top[0].toLowerCase()}. `
    + (sh?`They share ${A.base.filter(n=>B.base.includes(n)).join(' and ').toLowerCase()} in the base, so they bond instead of clashing. `:`Different bases, so this reads as two scents in conversation rather than one blend. `)
    + (A.weight>=B.weight?`The weight order is right â€” heavy under light.`:`Heads up: ${B.name} is heavier. Try swapping the order.`);
}
function renderLab(){
  const mk=(w,sel)=>SCENTS.map(s=>`<button class="lab-chip ${s.id===sel?'on':''}" data-w="${w}" data-s="${s.id}"><span class="dot" style="background:${s.hex}"></span>${s.name}</button>`).join('');
  $('labA').innerHTML=mk('a',layA); $('labB').innerHTML=mk('b',layB);
  paintMix();
}
['labA','labB'].forEach(id=>{
  $(id).onclick=e=>{
    const b=e.target.closest('.lab-chip'); if(!b) return;
    if(b.dataset.w==='a') layA=b.dataset.s; else layB=b.dataset.s;
    if(layA===layB) toast('Pick two different scents to layer');
    renderLab();
  };
});
function paintMix(){
  const p=pairOf(layA,layB), sc=scoreOf(layA,layB), A=S(layA), B=S(layB);
  $('mixName').textContent = p?p.n:`${A.name} Ã— ${B.name}`;
  $('mixTag').textContent = p?'A blend we know works':'Your blend';
  $('mixNum').textContent = sc+'% match';
  $('mixFill').style.width = sc+'%';
  const col = sc>=85?'#5DCAA5':sc>=70?'#EF9F27':'#F09595';
  $('mixFill').style.background=col; $('mixNum').style.color=col;
  $('mixDesc').textContent = p?p.d:autoDesc(layA,layB);
  $('mixHow').innerHTML=`<b>1.</b> Two sprays of ${A.name} on the chest and wrists.<br/><b>2.</b> Wait 30 seconds â€” let it dry down.<br/><b>3.</b> One spray of ${B.name} over the top. One, not two.`;
  $('mixBuy').textContent=`Add both â€” 25ml Â· ${inr(priceFor('25',2))}`;
  $('mixBuyBig').textContent=`Add both â€” 100ml Â· ${inr(priceFor('100',2))}`;
}
$('mixBuy').onclick=()=>loadPair('25');
$('mixBuyBig').onclick=()=>loadPair('100');
function loadPair(sz){
  if(layA===layB){toast('Pick two different scents'); return;}
  size=sz; cur=S(layA); qty=2; combo=[layA,layB];
  $('bottle').className='bottle '+(sz==='100'?'big':'small');
  $('scaleNote').textContent=SIZES[sz].label+' â€” shown to scale';
  $('labelSize').textContent='Extrait Â· '+SIZES[sz].label;
  setSize=sz;
  renderSizes(); renderTiers(); renderBulk(); renderPicker(); renderAddons(); paintScent(); calc(); drydown(); renderIngredients(); renderCombos(); paintSeg();
  window.scrollTo({top:0,behavior:'smooth'});
  toast(`${S(layA).name} + ${S(layB).name} â€” ${SIZES[sz].label}`);
}
function renderPresets(){
  $('presets').innerHTML = PAIRS.slice(0,4).map(p=>{
    const A=S(p.a),B=S(p.b);
    return `<button class="preset" data-a="${p.a}" data-b="${p.b}">
      <span class="pdots"><i style="background:${A.hex}"></i><i style="background:${B.hex}"></i></span>
      <div class="pn">${p.n}</div>
      <div class="pp">${A.name} + ${B.name}<br/>${p.score}% match Â· ${inr(SIZES['25'].unit*2-199)} in 25ml</div>
    </button>`;
  }).join('');
  $('presets').querySelectorAll('.preset').forEach(b=>{
    b.onclick=()=>{layA=b.dataset.a; layB=b.dataset.b; renderLab(); $('layering').scrollIntoView({behavior:'smooth'});};
  });
}

/* â”€â”€ SETS â”€â”€ */
$('setSeg').onclick=e=>{const b=e.target.closest('button'); if(!b) return; setSize=b.dataset.sz; paintSeg(); renderCombos();};
function paintSeg(){$('setSeg').querySelectorAll('button').forEach(b=>b.classList.toggle('on',b.dataset.sz===setSize));}
function renderCombos(){
  const list=SETS.filter(s=>s.sz===setSize), c=SIZES[setSize];
  $('combos').innerHTML=list.map(s=>{
    const mrp=s.ids.length*c.unit, ml=s.ids.length*c.ml;
    const bots=s.ids.map(id=>{const sc=S(id); return `<span class="mini ${setSize==='100'?'big':'small'}" style="background:${sc.soft};border:1px solid ${sc.hex}33"><i style="background:${sc.hex}"></i></span>`;}).join('');
    return `<div class="combo"><div class="combo-top">${bots}</div><div class="combo-body">
      <div class="combo-n">${s.n}</div><div class="combo-d">${s.d}</div>
      <div class="combo-p"><span class="a">${inr(s.p)}</span><span class="b">${inr(mrp)}</span><span class="c">Save ${inr(mrp-s.p)}</span></div>
      <div class="combo-ml">${s.ids.length} Ã— ${c.label} Â· ${ml}ml Â· ${inr(s.p/ml)} per ml</div>
      <button class="combo-btn" data-set="${s.n}">Add the set</button>
      <div class="combo-perk">Free shipping Â· gift box included</div>
    </div></div>`;
  }).join('');
  $('combos').querySelectorAll('.combo-btn').forEach(b=>{
    b.onclick=()=>{
      const s=SETS.find(x=>x.n===b.dataset.set);
      size=s.sz; qty=s.ids.length; combo=[...s.ids]; cur=S(combo[0]);
      $('bottle').className='bottle '+(size==='100'?'big':'small');
      $('scaleNote').textContent=SIZES[size].label+' â€” shown to scale';
      $('labelSize').textContent='Extrait Â· '+SIZES[size].label;
      renderSizes(); renderTiers(); renderBulk(); renderPicker(); renderAddons(); paintScent(); calc(); drydown(); renderIngredients();
      window.scrollTo({top:0,behavior:'smooth'});
      toast(`${s.n} added â€” ${SIZES[size].label}`);
    };
  });
}

/* â”€â”€ PINCODE â”€â”€ */
$('pinBtn').onclick=()=>{
  const p=$('pinIn').value.trim();
  if(!/^\d{6}$/.test(p)){toast('Enter a valid 6-digit pincode'); return;}
