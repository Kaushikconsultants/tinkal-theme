








<style>
:root{
  --ink:#15120F; --ink-2:#3B342D; --ink-3:#7A716A;
  --porcelain:#FCFBF9; --paper:#F3F0EB; --line:#E2DCD3; --line-2:#CFC7BB;
  --accent:#8C3A1E; --accent-soft:#F6EBE6;
  --good:#2F6B4F; --good-soft:#E8F1EC;
  --max:1240px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Jost',system-ui,sans-serif;background:var(--porcelain);color:var(--ink);font-weight:300;line-height:1.6;-webkit-font-smoothing:antialiased}
img{max-width:100%;display:block}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,select{font-family:inherit}
.eyebrow{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-3)}

.ticker{background:var(--ink);color:var(--porcelain);font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;text-align:center;padding:9px 16px}
.ticker b{color:#E8C79A;font-weight:400}
header{position:sticky;top:0;z-index:60;background:rgba(252,251,249,.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
.nav{max-width:var(--max);margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:20px}
.logo{font-family:'Bodoni Moda',serif;font-size:22px;letter-spacing:.22em;text-transform:uppercase}
.nav-links{display:flex;gap:26px;font-size:13px;color:var(--ink-2)}
.nav-links span{cursor:pointer}.nav-links span:hover{color:var(--accent)}
.nav-icons{display:flex;gap:18px;font-size:13px;letter-spacing:.06em}
@media(max-width:900px){.nav-links{display:none}}

.wrap{max-width:var(--max);margin:0 auto;padding:0 24px}
.pdp{display:grid;grid-template-columns:1.05fr .95fr;gap:64px;padding:44px 0 64px}
@media(max-width:980px){.pdp{grid-template-columns:1fr;gap:34px;padding:24px 0 40px}}

/* gallery */
.gallery{position:sticky;top:78px;align-self:start}
@media(max-width:980px){.gallery{position:static}}
.hero-frame{position:relative;aspect-ratio:4/5;border:1px solid var(--line);background:var(--accent-soft);display:flex;align-items:flex-end;justify-content:center;overflow:hidden;transition:background .7s ease;padding-bottom:10%}
.hero-frame::after{content:"";position:absolute;inset:0;background:radial-gradient(120% 90% at 50% 105%,rgba(0,0,0,.10),transparent 60%);pointer-events:none}
.bottle{position:relative;filter:drop-shadow(0 26px 36px rgba(0,0,0,.22));transition:width .6s cubic-bezier(.2,.8,.2,1),transform .6s}
.bottle.big{width:42%;aspect-ratio:.62}
.bottle.small{width:24%;aspect-ratio:.55}
.hero-frame:hover .bottle{transform:translateY(-8px)}
.bottle-cap{position:absolute;top:0;left:32%;width:36%;height:16%;background:var(--ink);border-radius:1px}
.bottle-neck{position:absolute;top:15%;left:40%;width:20%;height:7%;background:#C9BCA8}
.bottle-body{position:absolute;top:21%;left:0;width:100%;height:79%;background:linear-gradient(105deg,rgba(255,255,255,.55),rgba(255,255,255,.05) 38%,rgba(0,0,0,.10));border-radius:2px}
.bottle-liquid{position:absolute;bottom:0;left:0;width:100%;height:66%;background:var(--accent);opacity:.88;transition:background .7s ease}
.bottle-label{position:absolute;top:34%;left:12%;width:76%;background:rgba(252,251,249,.94);padding:10px 6px;text-align:center;border:.5px solid rgba(0,0,0,.08)}
.bottle-label .bn{font-family:'Bodoni Moda',serif;font-size:10px;letter-spacing:.18em;text-transform:uppercase;line-height:1.4}
.bottle-label .bs{font-family:'Space Mono',monospace;font-size:6px;letter-spacing:.12em;color:var(--ink-3);margin-top:3px}
.bottle.small .bottle-label{top:32%;padding:7px 4px}
.bottle.small .bottle-label .bn{font-size:7px}
.bottle.small .bottle-label .bs{font-size:5px}
.gal-tag{position:absolute;top:14px;left:14px;z-index:2;background:var(--porcelain);border:1px solid var(--line);padding:5px 10px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.14em;text-transform:uppercase}
.scale-note{position:absolute;bottom:14px;right:14px;z-index:2;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.1em;color:var(--ink-3);text-transform:uppercase}
.thumbs{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-top:8px}
.thumb{aspect-ratio:1;border:1px solid var(--line);background:var(--paper);display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:8px;color:var(--ink-3);text-align:center;line-height:1.3;padding:4px;cursor:pointer;transition:.2s}
.thumb:hover{border-color:var(--accent);color:var(--accent)}
.thumb.on{border-color:var(--ink);color:var(--ink)}

/* buy */
.title-row{display:flex;align-items:flex-start;justify-content:space-between;gap:16px}
h1{font-family:'Bodoni Moda',serif;font-weight:400;font-size:46px;line-height:1.05}
@media(max-width:600px){h1{font-size:34px}}
.conc{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.16em;text-transform:uppercase;border:1px solid var(--line-2);padding:5px 8px;white-space:nowrap;margin-top:6px}
.oneline{font-size:16px;color:var(--ink-2);margin-top:10px;max-width:44ch}
.stars{display:flex;align-items:center;gap:9px;margin-top:14px;font-size:13px;color:var(--ink-2);flex-wrap:wrap}
.stars .s{color:var(--accent);letter-spacing:2px;font-size:14px}
.stars a{color:var(--ink-2);text-decoration:underline;text-underline-offset:3px;cursor:pointer}
.vbadge{display:inline-flex;align-items:center;gap:5px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--good);border:1px solid #CBE0D4;background:var(--good-soft);padding:3px 8px}
.sec{margin-top:30px}
.sec-h{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:12px;gap:12px}

/* sizes */
.sizes{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.size{position:relative;border:1px solid var(--line);padding:16px 14px;text-align:left;background:var(--porcelain);transition:.18s}
.size:hover{border-color:var(--line-2)}
.size.on{border-color:var(--ink);box-shadow:inset 0 0 0 1px var(--ink)}
.size .sz-t{font-family:'Bodoni Moda',serif;font-size:22px;line-height:1.1}
.size .sz-r{font-size:12px;color:var(--ink-3);margin-top:2px}
.size .sz-p{font-family:'Space Mono',monospace;font-size:13px;margin-top:12px}
.size .sz-ml{font-family:'Space Mono',monospace;font-size:9px;color:var(--ink-3);margin-top:4px}
.size .sz-ml.win{color:var(--good)}
.size .badge{position:absolute;top:-9px;right:10px;background:var(--good);color:#fff;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:3px 7px}
.size-hint{font-family:'Space Mono',monospace;font-size:10px;color:var(--ink-3);margin-top:10px;line-height:1.7}
.size-hint b{color:var(--accent);font-weight:400;cursor:pointer;border-bottom:1px solid currentColor}

.scents{display:flex;flex-wrap:wrap;gap:7px}
.chip{display:flex;align-items:center;gap:7px;border:1px solid var(--line);padding:7px 11px 7px 8px;font-size:13px;transition:.18s;background:var(--porcelain)}
.chip .dot{width:9px;height:9px;border-radius:50%;flex:none}
.chip:hover{border-color:var(--line-2)}
.chip.on{border-color:var(--ink);background:var(--ink);color:var(--porcelain)}

.tier{position:relative;display:grid;grid-template-columns:22px 1fr auto;gap:14px;align-items:center;border:1px solid var(--line);padding:16px;margin-bottom:8px;transition:.18s;background:var(--porcelain);text-align:left;width:100%}
.tier:hover{border-color:var(--line-2)}
.tier.on{border-color:var(--ink);box-shadow:inset 0 0 0 1px var(--ink)}
.radio{width:16px;height:16px;border:1px solid var(--line-2);border-radius:50%;position:relative}
.tier.on .radio{border-color:var(--ink)}
.tier.on .radio::after{content:"";position:absolute;inset:3px;border-radius:50%;background:var(--ink)}
.tier-name{font-size:16px}
.tier-sub{font-family:'Space Mono',monospace;font-size:10px;color:var(--ink-3);margin-top:3px;display:block}
.tier-price{text-align:right}
.tier-price .p{font-size:18px}
.tier-price .strike{font-size:12px;color:var(--ink-3);text-decoration:line-through}
.badge{position:absolute;top:-9px;right:12px;background:var(--ink);color:var(--porcelain);font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;padding:3px 8px}
.badge.g{background:var(--good)}

.picker{border:1px solid var(--line);border-top:none;padding:16px;background:var(--paper);margin-top:-8px;margin-bottom:8px}
.pick-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.pick-n{font-family:'Space Mono',monospace;font-size:10px;color:var(--ink-3);width:60px}
.pick-row select{flex:1;border:1px solid var(--line-2);background:var(--porcelain);padding:9px 10px;font-size:14px;border-radius:0;color:var(--ink)}
.pick-tip{font-family:'Space Mono',monospace;font-size:9px;color:var(--good);margin-top:10px;line-height:1.7}

.savings{display:flex;justify-content:space-between;align-items:center;background:var(--good-soft);border:1px solid #CBE0D4;padding:11px 14px;margin-bottom:14px;font-size:14px;color:var(--good)}
.savings b{font-weight:500}

.addon{display:flex;align-items:center;gap:12px;border:1px solid var(--line);padding:12px 14px;margin-bottom:8px;font-size:14px;background:var(--porcelain);width:100%;text-align:left}
.addon.on{border-color:var(--ink)}
.box{width:16px;height:16px;border:1px solid var(--line-2);flex:none;position:relative}
.addon.on .box{background:var(--ink);border-color:var(--ink)}
.addon.on .box::after{content:"";position:absolute;left:5px;top:1px;width:4px;height:9px;border:solid var(--porcelain);border-width:0 1.5px 1.5px 0;transform:rotate(45deg)}
.addon .ad-t{flex:1}
.addon .ad-p{font-family:'Space Mono',monospace;font-size:12px}
.addon .ad-s{font-size:12px;color:var(--ink-3);display:block;margin-top:1px}

.total{display:flex;align-items:baseline;justify-content:space-between;padding:16px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin:20px 0 16px}
.total .tl{font-size:14px;color:var(--ink-2)}
.total .tr{display:flex;align-items:baseline;gap:10px}
.total .amt{font-family:'Bodoni Moda',serif;font-size:32px}
.total .was{font-size:14px;color:var(--ink-3);text-decoration:line-through}
.ctas{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.cta{width:100%;background:var(--porcelain);color:var(--ink);border:1px solid var(--ink);padding:19px;font-size:13px;letter-spacing:.14em;text-transform:uppercase;transition:.2s}
.cta:hover{background:var(--paper)}
.cta.buy{background:var(--ink);color:var(--porcelain);border-color:var(--ink)}
.cta.buy:hover{background:var(--accent);border-color:var(--accent)}
.cta-note{text-align:center;font-family:'Space Mono',monospace;font-size:10px;color:var(--ink-3);margin-top:10px;line-height:1.7}
@media(max-width:400px){.ctas{grid-template-columns:1fr}}

/* ---- BULK BOX ---- */
.bulk{border:1px solid var(--line);background:var(--paper);margin-top:8px}
.bulk-h{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:15px 16px;width:100%;text-align:left;cursor:pointer}
.bulk-h .bh-t{font-size:15px}
.bulk-h .bh-s{font-family:'Space Mono',monospace;font-size:10px;color:var(--ink-3);margin-top:3px;display:block}
.bulk-h .pm{font-family:'Space Mono',monospace;font-size:16px;color:var(--ink-3);transition:.2s}
.bulk.open .bulk-h .pm{transform:rotate(45deg)}
.bulk-b{max-height:0;overflow:hidden;transition:max-height .4s ease}
.bulk.open .bulk-b{max-height:520px}
.bulk-in{padding:0 16px 18px}
.ladder{display:grid;grid-template-columns:repeat(10,1fr);gap:4px;margin-bottom:14px}
.rung{border:1px solid var(--line-2);background:var(--porcelain);padding:9px 2px;text-align:center;transition:.15s}
.rung:hover{border-color:var(--ink)}
.rung .rq{font-family:'Bodoni Moda',serif;font-size:15px;line-height:1}
.rung .ro{font-family:'Space Mono',monospace;font-size:7px;color:var(--ink-3);margin-top:4px;letter-spacing:.02em}
.rung.on{background:var(--ink);border-color:var(--ink);color:var(--porcelain)}
.rung.on .ro{color:#B7ADA1}
.rung.reached{border-color:var(--good);color:var(--good)}
.rung.reached .ro{color:var(--good)}
.rung.on.reached{background:var(--good);border-color:var(--good);color:#fff}
.rung.on.reached .ro{color:#D3E7DB}
.step{display:flex;align-items:center;gap:14px;border:1px solid var(--line-2);background:var(--porcelain);padding:8px 10px;margin-bottom:12px}
.step button{width:34px;height:34px;border:1px solid var(--line-2);font-family:'Space Mono',monospace;font-size:15px;transition:.15s}
.step button:hover{border-color:var(--ink);background:var(--ink);color:var(--porcelain)}
.step .sv{flex:1;text-align:center}
.step .sv b{font-family:'Bodoni Moda',serif;font-size:22px;font-weight:400}
.step .sv span{font-family:'Space Mono',monospace;font-size:10px;color:var(--ink-3);display:block;margin-top:2px}
.step .sp{text-align:right}
.step .sp b{font-size:17px;font-weight:400}
.step .sp span{font-family:'Space Mono',monospace;font-size:9px;color:var(--good);display:block;margin-top:2px}
.nudge{background:var(--good-soft);border:1px solid #CBE0D4;padding:10px 12px;font-family:'Space Mono',monospace;font-size:10px;color:var(--good);line-height:1.7;display:flex;justify-content:space-between;align-items:center;gap:10px}
.nudge button{border-bottom:1px solid currentColor;font-family:'Space Mono',monospace;font-size:10px;color:var(--good);white-space:nowrap;text-transform:uppercase;letter-spacing:.08em}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
@media(max-width:520px){.grid2{grid-template-columns:1fr}.ladder{grid-template-columns:repeat(5,1fr)}}

/* ---- TRUST BADGES ---- */
.secure{display:flex;align-items:center;justify-content:center;gap:7px;margin-top:16px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3)}
.secure svg{width:12px;height:12px;stroke:var(--good);fill:none;stroke-width:1.6}
.pays{display:flex;flex-wrap:wrap;justify-content:center;gap:6px;margin-top:10px}
.pay-badge{border:1px solid var(--line);background:var(--porcelain);padding:5px 9px;font-family:'Space Mono',monospace;font-size:8px;letter-spacing:.08em;color:var(--ink-3);text-transform:uppercase}
.ship-bar{margin-top:20px}
.ship-track{height:3px;background:var(--line)}
.ship-fill{height:100%;background:var(--good);width:0;transition:width .5s cubic-bezier(.2,.8,.2,1)}
.ship-txt{font-family:'Space Mono',monospace;font-size:10px;color:var(--ink-3);margin-top:7px}
.ship-txt.done{color:var(--good)}

.pin{margin-top:22px;border:1px solid var(--line);padding:16px}
.pin-in{display:flex;gap:8px}
.pin-in input{flex:1;border:1px solid var(--line-2);background:var(--porcelain);padding:11px 12px;font-size:14px;border-radius:0;letter-spacing:.06em}
.pin-in input:focus{outline:none;border-color:var(--ink)}
.pin-in button{border:1px solid var(--ink);background:var(--ink);color:var(--porcelain);padding:0 20px;font-size:12px;letter-spacing:.1em;text-transform:uppercase}
.pin-out{margin-top:12px;font-size:13px;display:none}
.pin-out.show{display:block}
.pin-line{display:flex;align-items:flex-start;gap:8px;margin-bottom:5px;color:var(--ink-2)}
.pin-line .ic{font-family:'Space Mono',monospace;font-size:11px;color:var(--good)}

.trust{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:22px}
.trust-i{background:var(--porcelain);padding:16px 8px;text-align:center;font-size:11px;line-height:1.45;color:var(--ink-3)}
.trust-i svg{width:20px;height:20px;stroke:var(--ink);fill:none;stroke-width:1.3;margin:0 auto 8px}
.trust-i b{display:block;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink);font-weight:400;margin-bottom:3px}
@media(max-width:600px){.trust{grid-template-columns:repeat(2,1fr)}}

/* bands */
.band{border-top:1px solid var(--line);padding:72px 0}
.band.dark{background:var(--ink);color:var(--porcelain);border-top:none}
.band.dark .eyebrow{color:#8E8479}
.band-h{font-family:'Bodoni Moda',serif;font-weight:400;font-size:36px;margin-top:10px;line-height:1.15}
.band-sub{font-size:16px;color:var(--ink-3);margin-top:12px;max-width:58ch}
.band.dark .band-sub{color:#8E8479}
@media(max-width:600px){.band-h{font-size:27px}.band{padding:48px 0}}
.seg{display:inline-flex;border:1px solid var(--line);background:var(--porcelain)}
.band.dark .seg{border-color:#3A332C;background:transparent}
.seg button{padding:9px 16px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-3);transition:.18s}
.seg button.on{background:var(--ink);color:var(--porcelain)}
.band.dark .seg button.on{background:var(--porcelain);color:var(--ink)}

/* ---- CREDENTIAL BAR ---- */
.creds{display:grid;grid-template-columns:repeat(6,1fr);gap:1px;background:var(--line-2);border-top:1px solid var(--line-2);border-bottom:1px solid var(--line-2)}
.cred{background:var(--porcelain);padding:26px 12px;text-align:center}
.cred svg{width:26px;height:26px;stroke:var(--ink);fill:none;stroke-width:1.1;margin:0 auto 10px}
.cred .ct{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;line-height:1.6}
.cred .cs{font-size:11px;color:var(--ink-3);margin-top:5px;line-height:1.5}
@media(max-width:900px){.creds{grid-template-columns:repeat(3,1fr)}}
@media(max-width:560px){.creds{grid-template-columns:repeat(2,1fr)}}

/* ---- INGREDIENTS ---- */
.ing-head{display:flex;justify-content:space-between;align-items:flex-end;gap:20px;flex-wrap:wrap}
.ing-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-top:36px}
@media(max-width:1000px){.ing-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.ing-grid{grid-template-columns:repeat(2,1fr)}}
.ing{border:1px solid var(--line);background:var(--porcelain);overflow:hidden}
.ing-img{aspect-ratio:1;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.ing-img img{width:100%;height:100%;object-fit:cover}
.ing-img svg{width:64%;height:64%}
.ing-layer{position:absolute;top:8px;left:8px;font-family:'Space Mono',monospace;font-size:8px;letter-spacing:.1em;text-transform:uppercase;background:rgba(252,251,249,.92);padding:3px 6px;color:var(--ink-2)}
.ing-b{padding:14px}
.ing-n{font-family:'Bodoni Moda',serif;font-size:17px;line-height:1.25}
.ing-d{font-size:12px;color:var(--ink-3);margin-top:5px;line-height:1.55}
.ing-src{font-family:'Space Mono',monospace;font-size:8px;letter-spacing:.08em;color:var(--line-2);margin-top:9px;text-transform:uppercase}

/* drydown */
.dd{display:grid;grid-template-columns:1fr 1.15fr;gap:60px;align-items:center;margin-top:40px}
@media(max-width:900px){.dd{grid-template-columns:1fr;gap:34px}}
.dd-stage{font-family:'Bodoni Moda',serif;font-size:44px;line-height:1.1;margin-bottom:14px}
.dd-time{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#8E8479}
.dd-desc{font-size:16px;color:#C9C0B6;max-width:38ch;margin-top:14px;min-height:78px}
.dd-notes{display:flex;flex-wrap:wrap;gap:7px;margin-top:20px}
.dd-note{border:1px solid #3A332C;padding:6px 11px;font-size:13px;color:#8E8479;transition:.4s}
.dd-note.lit{border-color:var(--accent);color:#fff;background:var(--accent)}
.dd-viz{position:relative;height:230px}
.dd-curve{position:absolute;inset:0}
.dd-slider{width:100%;margin-top:26px;-webkit-appearance:none;background:transparent}
.dd-slider::-webkit-slider-runnable-track{height:2px;background:#3A332C}
.dd-slider::-moz-range-track{height:2px;background:#3A332C}
.dd-slider::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:var(--porcelain);margin-top:-8px;cursor:grab;border:3px solid var(--accent)}
.dd-slider::-moz-range-thumb{width:14px;height:14px;border-radius:50%;background:var(--porcelain);cursor:grab;border:3px solid var(--accent)}
.dd-ticks{display:flex;justify-content:space-between;margin-top:10px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.1em;color:#6E655C}

.two{display:grid;grid-template-columns:1fr 1fr;gap:60px;margin-top:40px}
