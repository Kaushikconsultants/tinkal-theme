};
$('pinIn').onkeydown=e=>{if(e.key==='Enter') $('pinBtn').click();};

/* â”€â”€ FAQ â”€â”€ */
const FAQ=[
  ['Is the 25ml a weaker version?','No. Identical Extrait concentration, 20â€“30% oil. Same juice, smaller bottle. The only difference is how long it lasts you, not how long it lasts on you.'],
  ['Which size should I buy first?','If you already know you love the scent â€” 100ml, it works out â‚¹8 cheaper per ml. If you\'re guessing â€” 25ml, and we credit it back when you upgrade.'],
  ['What is layering, actually?','Wearing two perfumes at once. Spray the heavier one first, let it settle thirty seconds, then one spray of the lighter one on top. You get a scent nobody else in the room is wearing. The layering lab tells you which pairs work.'],
  ['How do I know it\'s authentic?','Every bottle carries a batch code on the base, traceable to the day it was filled in our unit. We manufacture our own fragrances â€” there is no reseller in the chain.'],
  ['Is it safe for sensitive skin?','All formulas are IFRA compliant and dermatologically tested. Spray on clothing rather than skin if you\'re sensitive, and patch-test first.'],
  ['Can I mix scents inside a combo?','Yes. Every multi-bottle tier lets you pick any scents from the collection. The price doesn\'t change.']
];
$('faq').innerHTML=FAQ.map(([q,a])=>`<div class="q"><div class="q-t"><span>${q}</span><span class="pm">+</span></div><div class="q-a">${a}</div></div>`).join('');
$('faq').onclick=e=>{const q=e.target.closest('.q'); if(q) q.classList.toggle('open');};

$('thumbs').onclick=e=>{
