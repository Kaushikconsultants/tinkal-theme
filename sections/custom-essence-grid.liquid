<style>
  .custom-essence-grid--{{ section.id }} {
    padding: {{ section.settings.padding_y }}px 0;
    background-color: {{ section.settings.bg_color }};
  }
  .custom-essence-grid__title {
    text-align: center;
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    margin-bottom: 40px;
    font-weight: 600;
  }
  .custom-essence-grid__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .custom-essence-grid__item {
    background: #fff;
    border-radius: 12px;
    padding: 30px 20px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    border: 1px solid #f0f0f0;
  }
  .custom-essence-grid__icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f7ede2;
  }
  .custom-essence-grid__icon img {
    max-width: 30px;
    max-height: 30px;
    object-fit: contain;
  }
  .custom-essence-grid__item-title {
    font-size: 15px;
    font-weight: 700;
    color: #222;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .custom-essence-grid__item-desc {
    font-size: 13px;
    color: #666;
    line-height: 1.5;
  }
  
  @media screen and (max-width: 990px) {
    .custom-essence-grid__container {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 750px) {
    .custom-essence-grid__container {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 15px;
      padding-bottom: 10px;
    }
    .custom-essence-grid__container::-webkit-scrollbar {
      display: none;
    }
    .custom-essence-grid__item {
      flex: 0 0 85%;
      scroll-snap-align: center;
    }
    .custom-essence-grid__title {
      font-size: {{ section.settings.title_size | divided_by: 1.5 }}px;
    }
  }
</style>

<div class="custom-essence-grid--{{ section.id }}">
  {%- if section.settings.title != blank -%}
    <div class="custom-essence-grid__title">{{ section.settings.title }}</div>
  {%- endif -%}

  <div class="custom-essence-grid__container">
    {%- for block in section.blocks -%}
      <div class="custom-essence-grid__item" {{ block.shopify_attributes }}>
        <div class="custom-essence-grid__icon">
          {%- if block.settings.custom_svg != blank -%}
            {{ block.settings.custom_svg }}
          {%- elsif block.settings.icon != blank -%}
            {{ block.settings.icon | image_url: width: 100 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        {%- if block.settings.title != blank -%}
          <div class="custom-essence-grid__item-title">{{ block.settings.title }}</div>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <div class="custom-essence-grid__item-desc">{{ block.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Essence Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Essence of Our Brand"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Heading Size",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top/Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "grid_item",
      "name": "Essence Item",
      "settings": [
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG Code",
          "info": "Overrides the image picker. Recommended width/height: 28px."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon/Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Essence Grid",
      "blocks": [
        { "type": "grid_item" },
        { "type": "grid_item" },
        { "type": "grid_item" }
      ]
    }
  ]
}
{% endschema %}
